{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd linker-agent11 && npm install --include=optional && npm run build",
  "outputDirectory": "linker-agent11/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
