{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm --prefix linker-agent11 install --include=optional --optional=true",
  "buildCommand": "npm --prefix linker-agent11 run build",
  "outputDirectory": "linker-agent11/dist",
  "functions": {
    "linker-agent11/api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/linker-agent11/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
